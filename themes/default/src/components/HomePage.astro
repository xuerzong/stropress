---
import Icon from "./Icon.astro";
import {
  homeConfig,
  siteDescription,
  siteTitle,
  type HomeAction,
} from "../lib/config";

const heroTitle = homeConfig.title || siteTitle;
const heroTagline = homeConfig.tagline || siteDescription;
const heroDescription = homeConfig.description || siteDescription;
const actions = homeConfig.actions || [];
const features = homeConfig.features || [];

function getActionClass(action: HomeAction) {
  return action.theme === "alt" ? "action alt" : "action brand";
}
---

<section class="hero">
  <p class="eyebrow">Stropress</p>
  <h1>{heroTitle}</h1>
  <p class="tagline">{heroTagline}</p>
  <p class="description">{heroDescription}</p>

  {
    actions.length > 0 && (
      <div class="actions">
        {actions.map((action) => (
          <a class={getActionClass(action)} href={action.link}>
            {action.text}
          </a>
        ))}
      </div>
    )
  }
</section>

{
  features.length > 0 && (
    <section class="features">
      {features.map((feature) => (
        <article class="feature-card">
          <Icon
            name={feature.icon}
            class="feature-icon"
            aria-hidden="true"
            stroke-width={1.8}
          />
          <h2>{feature.title}</h2>
          <p>{feature.details}</p>
        </article>
      ))}
    </section>
  )
}

<style>
  .hero {
    padding: 1.5rem;
  }

  .eyebrow {
    display: inline-flex;
    margin: 0 0 1rem;
    padding: 0.15rem 0;
    border-radius: 0;
    background: transparent;
    color: var(--foreground-color);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 1px solid
      color-mix(in srgb, var(--foreground-color) 18%, transparent);
  }

  h1 {
    margin: 0;
    max-width: 10ch;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    font-size: clamp(3.4rem, 9vw, 6.8rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .tagline {
    margin: 1.25rem 0 0;
    max-width: 24ch;
    font-size: clamp(1.35rem, 3vw, 2rem);
    color: var(--foreground-color);
  }

  .description {
    margin: 1rem 0 0;
    max-width: 60ch;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted-color);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 148px;
    padding: 0.9rem 1.2rem;
    border-radius: 0;
    font-weight: 700;
    transition:
      transform 140ms ease,
      background 140ms ease;
  }

  .action:hover {
    transform: translateY(-1px);
  }

  .action.brand {
    background: var(--primary-color);
    color: var(--primary-foreground-color);
  }

  .action.alt {
    background: var(--secondary-color);
    border: 1px solid
      color-mix(in srgb, var(--foreground-color) 14%, transparent);
    color: var(--foreground-color);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 3rem;
    border-top: 1px solid
      color-mix(in srgb, var(--foreground-color) 12%, transparent);
  }

  .feature-card {
    padding: 1.5rem;
    border-right: 1px solid
      color-mix(in srgb, var(--foreground-color) 12%, transparent);
    background: transparent;
  }

  .feature-card:last-child {
    border-right: 0;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    margin-bottom: 1rem;
    padding: 0;
    border-radius: 0;
    background: transparent;
    color: var(--foreground-color);
  }

  .feature-card h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .feature-card p {
    margin: 0.75rem 0 0;
    color: var(--muted-color);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .features {
      grid-template-columns: 1fr;
    }

    .feature-card {
      padding-right: 0;
      border-right: 0;
      border-bottom: 1px solid
        color-mix(in srgb, var(--foreground-color) 12%, transparent);
    }

    .feature-card:last-child {
      border-bottom: 0;
    }
  }
</style>
