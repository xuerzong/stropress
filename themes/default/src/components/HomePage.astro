---
import Icon from "./Icon.astro";
import { getResolvedSiteConfig, type HomeAction } from "../lib/config";

const resolvedConfig = getResolvedSiteConfig(Astro.url.pathname);
const homeConfig = resolvedConfig.homeConfig;
const siteTitle = resolvedConfig.siteTitle;
const siteDescription = resolvedConfig.siteDescription;

const heroTitle = homeConfig.title || siteTitle;
const heroTagline = homeConfig.tagline || siteDescription;
const heroDescription = homeConfig.description || siteDescription;
const actions = homeConfig.actions || [];
const features = homeConfig.features || [];

const getActionClass = (action: HomeAction) =>
  action.theme === "alt" ? "action alt" : "action brand";
---

<section class="hero">
  <h1 class="hero-title">{heroTitle}</h1>
  <p class="tagline">{heroTagline}</p>
  <p class="description">{heroDescription}</p>

  {
    actions.length > 0 && (
      <div class="actions">
        {actions.map((action) => (
          <a class={getActionClass(action)} href={action.link}>
            {action.text}
          </a>
        ))}
      </div>
    )
  }
</section>

{
  features.length > 0 && (
    <section class="features">
      {features.map((feature) => (
        <article class="feature-card">
          <div class="feature-icon-wrapper">
            <Icon
              name={feature.icon}
              class="feature-icon"
              aria-hidden="true"
              stroke-width={1.8}
            />
          </div>
          <h2>{feature.title}</h2>
          <p>{feature.details}</p>
        </article>
      ))}
    </section>
  )
}

<style is:global>
  .hero {
    padding: 1.5rem;
  }

  .hero-title {
    margin: 0;
    font-size: 3rem;
    max-width: min(50vw, 100%);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }

  .tagline {
    margin: 1.25rem 0 0;
    max-width: 24ch;
    font-size: 1.25rem;
    color: rgba(var(--foreground-color) / 1);
  }

  .description {
    margin: 1rem 0 0;
    max-width: 60ch;
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(var(--muted-color) / 1);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 9rem;
    padding: 1rem 1.25rem;
    border-radius: var(--border-radius);
    font-weight: 700;
    transition:
      transform 140ms ease,
      background 140ms ease;
  }

  .action:hover {
    transform: translateY(-1px);
  }

  .action.brand {
    background: rgba(var(--primary-color) / 1);
    color: rgba(var(--primary-foreground-color) / 1);
  }

  .action.alt {
    background: rgba(var(--secondary-color) / 1);
    border: 1px solid rgba(var(--border-color) / 1);
    color: rgba(var(--foreground-color) / 1);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 3rem;
    border-top: 1px solid rgba(var(--border-color) / 1);
    border-bottom: 1px solid rgba(var(--border-color) / 1);
  }

  .feature-card {
    padding: 1.5rem;
    border-right: 1px solid rgba(var(--border-color) / 1);
    background: transparent;
  }

  .feature-card:last-child {
    border-right: 0;
  }

  .feature-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    margin-bottom: 1rem;
    border-radius: 0.75rem;
    background: rgba(var(--primary-color) / 0.1);
  }

  .feature-icon {
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    border-radius: 0;
    background: transparent;
    color: rgba(var(--foreground-color) / 1);
  }

  .feature-card h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .feature-card p {
    margin: 0.75rem 0 0;
    color: rgba(var(--muted-color) / 1);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .features {
      grid-template-columns: 1fr;
    }

    .feature-card {
      padding-right: 0;
      border-right: 0;
      border-bottom: 1px solid
        color-mix(in srgb, rgba(var(--foreground-color) / 1) 12%, transparent);
    }

    .feature-card:last-child {
      border-bottom: 0;
    }
  }
</style>
