---
import Icon from "./Icon.astro";
import { siteConfig, siteTitle } from "../lib/config";

const items = siteConfig.navbar || [];
---

<header class="topbar">
  <div class="brand">
    <a href="/">{siteTitle}</a>
  </div>
  <nav>
    <ul>
      {
        items.map((item) => (
          <li>
            <a href={item.link}>
              <Icon name={item.icon} class="nav-icon" aria-hidden="true" />
              <span>{item.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    backdrop-filter: blur(16px);
    background: color-mix(in srgb, var(--secondary-color) 88%, transparent);
    border-bottom: 1px solid
      color-mix(in srgb, var(--foreground-color) 14%, transparent);
  }

  .brand a {
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
  }

  a:hover {
    color: var(--foreground-color);
    background: var(--accent-color);
  }

  nav a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 12px;
    padding: 0.35rem 0.55rem;
  }

  .nav-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex: none;
  }

  @media (max-width: 900px) {
    .topbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    ul {
      flex-wrap: wrap;
    }
  }
</style>
