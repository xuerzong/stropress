---
import Icon from "./Icon.astro";
import { siteConfig, siteTitle } from "../lib/config";

const items = siteConfig.navbar || [];
---

<header class="header">
  <div class="logo">
    <a href="/">{siteTitle}</a>
  </div>
  <ul class="social-links-list">
    {
      items.map((item) => (
        <li>
          <a href={item.link} class="nav-link">
            <Icon name={item.icon} class="nav-icon" aria-hidden="true" />
          </a>
        </li>
      ))
    }
  </ul>
</header>

<style is:global>
  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    backdrop-filter: blur(8px);
    background: rgba(var(--background-color) / 0.85);
    border-bottom: 1px solid rgba(var(--border-color) / 1);
  }

  .logo a {
    font-weight: 700;
  }

  .social-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0;
    font-size: 0.875rem;
  }

  .nav-icon {
    width: 1rem;
    height: 1rem;
    flex: none;
  }

  @media (max-width: 900px) {
    .header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .social-links-list {
      flex-wrap: wrap;
    }
  }
</style>
