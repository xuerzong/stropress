---
import Icon from "./Icon.astro";
import { siteConfig } from "../lib/config";

const groups = siteConfig.sidebar || [];
const pathname = Astro.url.pathname;
---

<aside class="sidebar">
  {
    groups.map((group) => (
      <section>
        <h2>
          <Icon name={group.icon} class="group-icon" aria-hidden="true" />
          <span>{group.label}</span>
        </h2>
        <ul>
          {group.items.map((item) => (
            <li>
              <a
                href={item.link}
                class={pathname === item.link ? "active" : undefined}
              >
                <Icon name={item.icon} class="item-icon" aria-hidden="true" />
                <span>{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 5.5rem;
    align-self: start;
    padding: 1.25rem;
    background: var(--secondary-color);
    border: 1px solid
      color-mix(in srgb, var(--foreground-color) 12%, transparent);
    border-radius: 24px;
    box-shadow: 0 20px 60px rgb(from var(--foreground-color) r g b / 0.08);
  }

  h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted-color);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  section + section {
    margin-top: 1.25rem;
  }

  li + li {
    margin-top: 0.35rem;
  }

  a {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    display: block;
    padding: 0.55rem 0.75rem;
    border-radius: 12px;
    color: var(--muted-color);
  }

  .group-icon,
  .item-icon {
    flex: none;
  }

  .group-icon {
    width: 0.95rem;
    height: 0.95rem;
  }

  .item-icon {
    width: 0.9rem;
    height: 0.9rem;
  }

  a.active,
  a:hover {
    color: var(--foreground-color);
    background: var(--accent-color);
  }

  @media (max-width: 900px) {
    .sidebar {
      position: static;
    }
  }
</style>
