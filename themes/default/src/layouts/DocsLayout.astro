---
import NavBar from "../components/NavBar.astro";
import Sidebar from "../components/Sidebar.astro";
import { siteDescription, siteTitle } from "../lib/config";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  sidebar?: boolean;
}

const { title, description, sidebar = true } = Astro.props;
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description || siteDescription;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="shell">
      <NavBar />
      <div class:list={["content-shell", !sidebar && "content-shell-full"]}>
        {sidebar && <Sidebar />}
        <main class="content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  .shell {
    min-height: 100vh;
  }

  .content-shell {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem;
  }

  .content {
    background: var(--secondary-color);
    border: 1px solid
      color-mix(in srgb, var(--foreground-color) 12%, transparent);
    border-radius: 24px;
    box-shadow: 0 20px 60px rgb(from var(--foreground-color) r g b / 0.08);
    padding: 2rem clamp(1.25rem, 3vw, 3rem);
  }

  .content-shell-full {
    grid-template-columns: minmax(0, 1fr);
  }

  .content :global(h1),
  .content :global(h2),
  .content :global(h3) {
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    line-height: 1.05;
  }

  .content :global(h1) {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    margin-top: 0;
  }

  .content :global(p),
  .content :global(li) {
    line-height: 1.75;
    color: var(--muted-color);
  }

  .content :global(code),
  .content :global(pre) {
    font-family: "IBM Plex Mono", monospace;
  }

  .content :global(pre) {
    padding: 1rem;
    background: var(--primary-color);
    color: var(--primary-foreground-color);
    border-radius: 18px;
    overflow: auto;
  }

  @media (max-width: 900px) {
    .content-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
