---
import NavBar from "../components/NavBar.astro";
import Sidebar from "../components/Sidebar.astro";
import DocToc from "../components/DocToc.astro";
import { getResolvedSiteConfig } from "../lib/config";
import "../styles/global.css";
import "../styles/markdown.css";

interface Props {
  title?: string;
  description?: string;
  sidebar?: boolean;
  contentClass?: string;
  tocHeadings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  title,
  description,
  sidebar = true,
  contentClass = "",
  tocHeadings = [],
} = Astro.props;
const resolvedConfig = getResolvedSiteConfig(Astro.url.pathname);
const pageTitle = title
  ? `${title} | ${resolvedConfig.siteTitle}`
  : resolvedConfig.siteTitle;
const pageDescription = description || resolvedConfig.siteDescription;
const tocItems = tocHeadings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 3,
);
---

<!doctype html>
<html lang={resolvedConfig.localeLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Geist:wght@100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <NavBar showSidebarToggle={sidebar} />
    <div class:list={["wrapper", !sidebar && "wrapper-without-sidebar"]}>
      {
        sidebar && (
          <>
            <button
              type="button"
              class="sider-backdrop"
              data-sidebar-backdrop
              data-state="closed"
              aria-label="Close navigation menu"
            />
            <aside
              id="sidebar-drawer"
              class="sider"
              data-sidebar-drawer
              data-state="closed"
            >
              <Sidebar />
            </aside>
          </>
        )
      }
      <main class:list={["content", contentClass]}>
        <div
          class:list={[
            "docs-main",
            tocItems.length > 0 && "docs-main-with-toc",
          ]}
        >
          <div class="docs-main-content">
            <slot />
          </div>
          <DocToc items={tocItems} />
        </div>
      </main>
    </div>
    <script>
      import { setupCodeCopyButtons } from "../scripts/code-copy";

      setupCodeCopyButtons();

      let sidebarCleanup: (() => void) | null = null;

      const setupSidebarDrawer = () => {
        if (typeof sidebarCleanup === "function") {
          sidebarCleanup();
          sidebarCleanup = null;
        }

        const drawer = document.querySelector<HTMLElement>(
          "[data-sidebar-drawer]",
        );
        const backdrop = document.querySelector<HTMLElement>(
          "[data-sidebar-backdrop]",
        );
        const toggle = document.querySelector<HTMLElement>(
          "[data-sidebar-toggle]",
        );

        if (!drawer || !backdrop || !toggle) {
          return;
        }

        const linkElements = Array.from(
          drawer.querySelectorAll<HTMLAnchorElement>("a"),
        );

        const setOpen = (open: boolean) => {
          drawer.dataset.state = open ? "open" : "closed";
          backdrop.dataset.state = open ? "open" : "closed";
          toggle.setAttribute("aria-expanded", open ? "true" : "false");
          document.body.style.overflow = open ? "hidden" : "";
        };

        const close = () => setOpen(false);
        const onToggle = () => setOpen(drawer.dataset.state !== "open");

        toggle.addEventListener("click", onToggle);
        backdrop.addEventListener("click", close);
        linkElements.forEach((element: HTMLAnchorElement) =>
          element.addEventListener("click", close),
        );

        const onKeydown = (event: KeyboardEvent) => {
          if (event.key === "Escape") {
            close();
          }
        };

        const onResize = () => {
          if (window.innerWidth > 900) {
            close();
          }
        };

        document.addEventListener("keydown", onKeydown);
        window.addEventListener("resize", onResize);

        sidebarCleanup = () => {
          toggle.removeEventListener("click", onToggle);
          backdrop.removeEventListener("click", close);
          linkElements.forEach((element: HTMLAnchorElement) =>
            element.removeEventListener("click", close),
          );
          document.removeEventListener("keydown", onKeydown);
          window.removeEventListener("resize", onResize);
          document.body.style.overflow = "";
        };
      };

      setupSidebarDrawer();
      document.addEventListener("astro:page-load", setupSidebarDrawer);
    </script>
  </body>
</html>

<style is:global>
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .sider {
    flex-shrink: 0;
    width: 16rem;
  }

  .sider-backdrop {
    display: none;
  }

  .wrapper {
    display: flex;
    flex-direction: row;
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    flex: 1;
    min-height: 0;
  }

  .content {
    flex: 1;
    min-width: 0;
  }

  .docs-main {
    width: 100%;
    min-width: 0;
  }

  .wrapper-without-sidebar {
    max-width: unset;
    width: 100%;
  }

  @media (min-width: 1200px) {
    .docs-main-with-toc {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 15rem;
      gap: 2rem;
      align-items: start;
    }
  }

  @media (max-width: 900px) {
    .wrapper {
      flex-direction: column;
    }

    .sider-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 20;
      border: 0;
      background: rgba(0 0 0 / 0.4);
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease;
    }

    .sider-backdrop[data-state="open"] {
      opacity: 1;
      pointer-events: auto;
    }

    .sider {
      position: fixed;
      left: 0;
      top: 0;
      z-index: 30;
      width: min(84vw, 18rem);
      height: 100dvh;
      transform: translateX(-100%);
      transition: transform 220ms ease;
      background: rgba(var(--background-color) / 1);
      border-right: 1px solid rgba(var(--border-color) / 1);
      padding: 5rem 0.5rem 1rem;
      overflow-y: auto;
    }

    .sider[data-state="open"] {
      transform: translateX(0);
    }

    .content {
      border-left: 0;
      border-top: 1px solid
        color-mix(in srgb, rgba(var(--foreground-color) / 1) 12%, transparent);
      padding-inline: 0;
      padding-bottom: 0;
      padding-top: 1.5rem;
    }
  }
</style>
