        "icon": "Terminal",
        "title": "CLI Driven",
        "details": "Run stropress dev or stropress build against any docs directory by passing --dir."
      },
      {
        "icon": "SlidersHorizontal",
        "title": "Config First",
        "details": "Navbar, sidebar, homepage hero, CTA buttons, and features are all defined in config.json."
      }
