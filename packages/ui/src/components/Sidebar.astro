---
import Icon from "./Icon.astro";
import { getResolvedSiteConfig } from "../lib/config";

const groups = getResolvedSiteConfig(Astro.url.pathname).sidebar;
const pathname = Astro.url.pathname;

const normalizePath = (input: string) => {
  if (!input || input === "/") {
    return "/";
  }

  return input.endsWith("/") ? input.slice(0, -1) : input;
};

const currentPath = normalizePath(pathname);
---

<div class="sidebar">
  {
    groups.map((group) => (
      <section class="sidebar-link-group">
        <label class="sidebar-link-group-label">{group.label}</label>
        <ul class="sidebar-link-list">
          {group.items.map((item) => (
            <li class="sidebar-link-item">
              <a
                href={item.link}
                class="sidebar-link"
                data-state={
                  currentPath === normalizePath(item.link)
                    ? "active"
                    : "inactive"
                }
              >
                <span>{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</div>

<style is:global>
  .sidebar {
    position: sticky;
    top: 5.5rem;
  }

  .sidebar-link-group {
    font-size: 0.875rem;

    .sidebar-link-group-icon {
      width: 1.1rem;
      height: 1.1rem;
    }

    .sidebar-link-group-label {
      padding: 0.5rem;
      font-weight: 700;
    }
  }

  .sidebar-icon {
    width: 0.9rem;
    height: 0.9rem;
  }

  .sidebar-link-list {
    list-style: none;
    padding: 0.5rem;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 0.25rem;
    padding: 0.45rem 0.75rem;

    &[data-state="active"],
    &:hover {
      background: rgba(var(--accent-color) / 1);
      color: rgba(var(--foreground-color) / 1);
    }
  }

  @media (max-width: 900px) {
    .sidebar {
      position: static;
      padding: 0 0 1.5rem;
      border-bottom: 1px solid
        color-mix(in srgb, rgba(var(--foreground-color) / 1) 12%, transparent);
    }
  }
</style>
