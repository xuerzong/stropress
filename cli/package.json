{
  "name": "stropress",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "stropress": "dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "bun build src/index.ts --target=node --format=esm --packages=external --outfile dist/index.js",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationDir dist",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "dev": "bun src/index.ts dev",
    "pack:check": "bun run build && npm pack --dry-run"
  },
  "dependencies": {
    "@stropress/ui": "^0.0.4",
    "astro": "6.1.3",
    "commander": "^14.0.0",
    "fs-extra": "^11.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3"
  }
}
