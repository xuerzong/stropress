{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./schema.json",
  "title": "Stropress Config",
  "description": "Configuration schema for Stropress docs config.json files.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference used by editors for validation and autocompletion."
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "Canonical site URL used for SEO metadata such as canonical, og:url, and og:image.",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "description": "Site title shown in the navbar and page titles."
        },
        "description": {
          "type": "string",
          "description": "Default site description used in metadata and homepage fallbacks."
        },
        "favicon": {
          "type": "string",
          "description": "Path or URL for the favicon link tag, for example /favicon.svg or https://example.com/favicon.ico.",
          "minLength": 1
        }
      }
    },
    "home": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Homepage hero title."
        },
        "tagline": {
          "type": "string",
          "description": "Homepage hero subtitle."
        },
        "description": {
          "type": "string",
          "description": "Homepage hero description text."
        },
        "actions": {
          "type": "array",
          "description": "Homepage CTA buttons.",
          "items": {
            "$ref": "#/$defs/homeAction"
          }
        },
        "features": {
          "type": "array",
          "description": "Homepage feature cards.",
          "items": {
            "$ref": "#/$defs/homeFeature"
          }
        }
      }
    },
    "markdown": {
      "type": "object",
      "additionalProperties": false,
      "description": "Markdown rendering options.",
      "properties": {
        "codeTheme": {
          "$ref": "#/$defs/codeTheme"
        }
      }
    },
    "navbar": {
      "type": "array",
      "description": "Top navigation links.",
      "items": {
        "$ref": "#/$defs/navItem"
      }
    },
    "nav": {
      "type": "array",
      "description": "Primary header links rendered next to social links.",
      "items": {
        "$ref": "#/$defs/navItem"
      }
    },
    "socialLinks": {
      "type": "array",
      "description": "Top-right social links rendered as icons.",
      "items": {
        "$ref": "#/$defs/navItem"
      }
    },
    "sidebar": {
      "type": "array",
      "description": "Sidebar groups and links.",
      "items": {
        "$ref": "#/$defs/sidebarGroup"
      }
    },
    "footer": {
      "$ref": "#/$defs/footerConfig",
      "description": "Footer content shown at the bottom of the page."
    },
    "search": {
      "type": "object",
      "additionalProperties": false,
      "description": "Search behavior and provider configuration.",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["local"],
          "description": "Search provider. Local uses built-in MiniSearch."
        }
      }
    },
    "locales": {
      "type": "object",
      "description": "Bilingual or multilingual overrides by locale path prefix, for example '/' and '/zh/'.",
      "propertyNames": {
        "type": "string",
        "pattern": "^/.*"
      },
      "additionalProperties": {
        "$ref": "#/$defs/localeConfig"
      }
    }
  },
  "$defs": {
    "navItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "link"],
      "properties": {
        "icon": {
          "type": "string",
          "description": "Optional Lucide icon name shown before the link label."
        },
        "label": {
          "type": "string",
          "description": "Visible link text."
        },
        "link": {
          "type": "string",
          "description": "Absolute site path or external URL.",
          "minLength": 1
        }
      }
    },
    "sidebarGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "items"],
      "properties": {
        "icon": {
          "type": "string",
          "description": "Optional Lucide icon name shown before the group label."
        },
        "label": {
          "type": "string",
          "description": "Sidebar group title."
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/navItem"
          }
        }
      }
    },
    "homeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "link"],
      "properties": {
        "text": {
          "type": "string",
          "description": "CTA button text."
        },
        "link": {
          "type": "string",
          "description": "CTA target path or URL.",
          "minLength": 1
        },
        "theme": {
          "type": "string",
          "enum": ["brand", "alt"],
          "description": "Visual style for the CTA button."
        }
      }
    },
    "homeFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "details"],
      "properties": {
        "icon": {
          "type": "string",
          "description": "Optional Lucide icon name shown above the feature title, for example Rocket or Terminal."
        },
        "title": {
          "type": "string",
          "description": "Feature title."
        },
        "details": {
          "type": "string",
          "description": "Feature description."
        }
      }
    },
    "footerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "message": {
          "type": "string",
          "description": "Primary footer text shown above copyright."
        },
        "copyright": {
          "type": "string",
          "description": "Copyright text shown in the footer."
        }
      }
    },
    "localeConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "description": "Locale switcher label, for example English or 简体中文."
        },
        "lang": {
          "type": "string",
          "description": "Page language tag for html[lang], for example en-US or zh-CN."
        },
        "site": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "description": "Locale-specific canonical site URL when needed.",
              "format": "uri"
            },
            "title": {
              "type": "string",
              "description": "Locale-specific site title."
            },
            "description": {
              "type": "string",
              "description": "Locale-specific site description."
            },
            "favicon": {
              "type": "string",
              "description": "Locale-specific favicon path or URL.",
              "minLength": 1
            }
          }
        },
        "home": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string"
            },
            "tagline": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "actions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/homeAction"
              }
            },
            "features": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/homeFeature"
              }
            }
          }
        },
        "nav": {
          "type": "array",
          "description": "Locale-specific header links rendered next to social links.",
          "items": {
            "$ref": "#/$defs/navItem"
          }
        },
        "navbar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/navItem"
          }
        },
        "socialLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/navItem"
          }
        },
        "sidebar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sidebarGroup"
          }
        },
        "footer": {
          "$ref": "#/$defs/footerConfig"
        }
      }
    },
    "codeTheme": {
      "description": "Shiki theme for markdown code blocks. Supports a single theme name or light/dark themes.",
      "oneOf": [
        {
          "type": "string",
          "description": "Single theme name, for example github-dark or nord."
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["light", "dark"],
          "properties": {
            "light": {
              "type": "string",
              "description": "Theme used in light mode, for example github-light."
            },
            "dark": {
              "type": "string",
              "description": "Theme used in dark mode, for example github-dark."
            }
          }
        }
      ]
    }
  }
}
